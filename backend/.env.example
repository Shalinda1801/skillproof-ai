PORT=5000
NODE_ENV=development

# Local MongoDB example:
# MONGO_URI=mongodb://127.0.0.1:27017/skillproof_ai

# MongoDB Atlas example:
# MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/skillproof_ai
MONGO_URI=mongodb://127.0.0.1:27017/skillproof_ai

JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=7d

CLIENT_URL=http://localhost:5173

AI_PROVIDER=mock
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash